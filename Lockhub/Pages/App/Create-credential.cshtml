@page
@model Lockhub.Pages.App.Create_credentialModel
@{
    Layout = "_AppLayout";
}

<section class="main-section">
    <div class="create-login-header-container">
        <h1>Create credential</h1>
        <p style="font-weight:100;">Store a new login</p>
    </div>
    <div class="create-container">
        <form class="form-create-credential" method="post">
            <label class="label-head" for="">BASIC INFO</label>
            <div class="basic-info-container">
                <div class="one-long-container">
                    <label for="">Title*</label>
                    <input type="text" name="" id="" placeholder="e.g. Facebook account">
                </div>
                <div class="two-divided-container">
                    <div class="one-long-container percent-width">
                        <label for="">Username / Email*</label>
                        <input type="text" placeholder="you@example.com">
                    </div>
                    <div class="one-long-container percent-width two-divided-left">
                        <label for="">URL</label>
                        <input type="text" placeholder="https://facebook.com/">
                    </div>
                </div>
            </div>
            <label class="label-head" for="">PASSWORD</label>
            <div>
                <div class="one-long-container">
                    <label for="">Password*</label>
                    <input type="password" placeholder="Enter or generate a password">
                </div>
            </div>
            <label class="label-head" for="">ORGANISATION</label>
            <div class="organisation-info-container one-long-container">
                <label for="">Vault</label>
                <select name="org" id="">
                    <option value="none">--- Select an option ---</option>
                    <option value="">Foreach loop here with accessable vault names</option>
                </select>
            </div>
            <div class="submit-button-container">
                <button class="second-btn cancel-button" type="submit">Cancel</button>
                <button class="prim-btn submit-button" type="submit">Save credential</button>
            </div>
        </form>
    </div>
</section>