@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<main>
    <section class="hero-section">
        <div class="hero-s-left-container">
            <h1>Take control of your passwords</h1>
            <div class="hero-s-left-desc-container">
                <p>No more weak passwords or forgotten logins. <br>Just secure, seamless access to everything you need.</p>
                <ul>
                    <li>Generate unbreakable passwords instantly</li>
                    <li>Sync across all your devices</li>
                    <li>Autofill logins with one click</li>
                </ul>
            </div>
            <div class="hero-s-left-cta-container">
                <a href="#" class="button-hover make-this-hover hero-s-left-cta">Get started</a>
                <a href="#" class="button-hover make-this-hover hero-s-left-cta">See how it works</a>
            </div>
        </div>
        <div class="hero-s-right-container">
            <img src="/content/undraw_safe_0mei.svg" alt="">
        </div>
    </section>
    <section class="features-section">
        <h2 class="feature-header">Features</h2>
        <div class="cards-container">
            <div class="feature-cards">
                <img src="/content/encryption.png" alt="">
                <h3>Military-Grade Encryption</h3>
                <p>Your passwords are protected with Argon2 hashing and AES-256 encryption. Even we can't see your data. <br> True zero-knowledge security.</p>
                <a href="" class="button-hover make-this-hover hero-s-left-cta">Read more</a>
            </div>
            <div class="feature-cards">
                <img src="/content/anywhere.png" alt="">
                <h3>Access Anywhere</h3>
                <p>Seamlessly sync across all your devices. Desktop, mobile, tablet - your passwords are always available when you need them.</p>
                <a href="" class="button-hover make-this-hover hero-s-left-cta">Read more</a>
            </div>
            <div class="feature-cards">
                <img src="/content/tap.png" alt="">
                <h3>One-Click Autofill</h3>
                <p>Stop typing passwords manually. Lockhub automatically fills in your credentials with a single click across all your favorite sites.</p>
                <a href="" class="button-hover make-this-hover hero-s-left-cta">Read more</a>
            </div>
            <div class="feature-cards">
                <img src="/content/password.png" alt="">
                <h3>Password Generator</h3>
                <p>Create unbreakable passwords instantly. Custom length, symbols, and complexity settings ensure every account stays secure.</p>
                <a href="" class="button-hover make-this-hover hero-s-left-cta">Read more</a>
            </div>
            <div class="feature-cards">
                <img src="/content/security-breach.png" alt="">
                <h3>Breach Monitoring</h3>
                <p>Get alerted if your passwords appear in data breaches. Stay one step ahead of hackers with real-time security notifications.</p>
                <a href="" class="button-hover make-this-hover hero-s-left-cta">Read more</a>
            </div>
            <div class="feature-cards">
                <img src="/content/network.png" alt="">
                <h3>Secure Sharing</h3>
                <p>Share passwords with teammates or family safely. Encrypted sharing means no more sending passwords over text or email.</p>
                <a href="" class="button-hover make-this-hover hero-s-left-cta">Read more</a>
            </div>
        </div>
    </section>
    <section class="pricing-section">
        <div class="pricing-container">
            <div class="pricing-s-left-col">
                <div>
                    <h2>Simple, transparent pricing</h2>
                </div>
                <div class="pricing-desc-container">
                    <p>Start free and upgrade as you grow.</p>
                    <p>Lockhub gives you everything you need to secure your digital life without spending a dime.</p>
                    <p>As your needs expand, unlock advanced features like unlimited device sync, priority support, and secure sharing for teams.</p>
                    <p>No hidden fees, no credit card required to start. <br><br>Cancel anytime with zero hassle.</p>
                </div>
                <div class="pricing-desc-cta-container">
                    <a href="" class="button-hover make-this-hover hero-s-left-cta">See more pricing options</a>
                    <a href="" class="button-hover make-this-hover hero-s-left-cta">Get quote</a>
                </div>
            </div>
            <div class="pricing-s-right-col">
                <div class="free-tier-card">
                    <h2 class="gray-bg-white-text">Free forever</h2>
                    <p class="gray-bg-white-text">Everything you need to get started</p>
                    <p class="gray-bg-white-text">Price: $0</p>
                    <h3 class="gray-bg-white-text">Features</h3>
                    <div class="pricing-card-features-container">
                        <ul>
                            <li class="gray-bg-white-text">5 password storage slots</li>
                            <li class="gray-bg-white-text">Military-grade encryption (Argon2 + AES-256)</li>
                            <li class="gray-bg-white-text">Sync across all devices</li>
                            <li class="gray-bg-white-text">Password generator</li>
                            <li class="gray-bg-white-text">One-click autofill</li>
                            <li class="gray-bg-white-text">
                                Browser extensions
                                <p class="gray-bg-gray-text indent">- Chrome, Firefox, Safari</p>
                            </li>
                            <li class="gray-bg-white-text">Basic breach monitoring</li>
                        </ul>
                    </div>
                    <a href="" class="button-hover make-this-hover hero-s-left-cta gray-bg-white-text white-border">Get started</a>
                </div>
                <div class="mobile-pricing-desc-cta-container">
                    <a href="" class="button-hover make-this-hover hero-s-left-cta">See more pricing options</a>
                    <a href="" class="button-hover make-this-hover hero-s-left-cta">Get quote</a>
                </div>
            </div>
        </div>
    </section>
</main>
